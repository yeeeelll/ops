{
  "name": "ai-ops-agent",
  "version": "0.0.1",
  "private": true,
  "description": "AI ops agent with Telegram bot, OpenRouter backend",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
