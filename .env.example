# ===== OpenRouter / LLM =====
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model id on OpenRouter
LLM_MODEL=deepseek/deepseek-v4-flash
# Optional: name your app for OpenRouter dashboards
OPENROUTER_APP_NAME=ai-ops-agent
OPENROUTER_HTTP_REFERER=https://localhost
# Max tokens in a single LLM call response
LLM_MAX_TOKENS=4096
# Soft context budget; loop compresses when usage exceeds this fraction
LLM_CONTEXT_BUDGET=120000
LLM_COMPACT_THRESHOLD=0.8
# Max tool-call iterations per user turn (防死循环 + 防烧钱). 25 适合代码调查.
AGENT_MAX_ITERATIONS=25
# Single tool result truncation cap in characters
AGENT_TOOL_RESULT_MAX_CHARS=8000

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# Comma-separated user ids allowed to talk to the bot. REQUIRED for bot mode.
TELEGRAM_ALLOWED_USER_IDS=

# ===== Runtime =====
NODE_ENV=development
LOG_LEVEL=info
DATA_DIR=./data
LOG_DIR=./logs

# ===== Tool sandbox =====
# Comma-separated absolute paths that filesystem tools may READ under.
ALLOWED_PATHS=/opt,/var/log,/www,/etc/nginx
# Comma-separated absolute paths that are read-only even inside ALLOWED_PATHS.
READONLY_PATHS=/etc/nginx,/var/log
# Comma-separated absolute paths that write_file / edit_file may MUTATE.
# Empty = block all writes. Must be subset of ALLOWED_PATHS and disjoint from READONLY_PATHS.
# For multi-site: list each site dir explicitly so ACLs are granted per site:
#   WRITABLE_PATHS=/opt/ai-agent,/www/wwwroot/site-a,/www/wwwroot/site-b
WRITABLE_PATHS=/opt,/www/wwwroot
# Comma-separated absolute paths that NO tool may read or write, even if inside
# ALLOWED_PATHS. Defaults already include the agent's own .env, data dir,
# /etc/shadow, /etc/sudoers, /etc/sudoers.d, /root/.ssh — add more here.
DENY_PATHS=
# Comma-separated systemd unit names (or prefix*) service_op may control.
# Empty = no service writes allowed.
APPROVED_SERVICES=nginx,nginx.service,php-fpm*,redis-server,mysql
# Comma-separated absolute paths git_op may operate within.
APPROVED_GIT_REPOS=/opt/ai-agent,/www/wwwroot/your-project
# Shell command timeout in milliseconds
SHELL_TIMEOUT_MS=30000
# Hard kill timeout after timeout (SIGKILL grace)
SHELL_KILL_GRACE_MS=5000
# Approval prompt timeout (ms) before auto-denying a dangerous tool call
APPROVAL_TIMEOUT_MS=60000
# Whether service_op should prefix sudo. true / false / auto (auto = run as non-root)
USE_SUDO=auto

# ===== Database tool (db_query / db_write) =====
# Named DB connection profiles. Format: <name>:<DSN>,<name2>:<DSN2>
# DSN: mysql://user:pass@host:port/db  or  postgres://user:pass@host:port/db
# Prefer separate read-only / read-write users so db_query stays sandboxed.
# The LLM only sees profile NAMES (e.g. "main_ro"), never the password.
# Example:
#   DB_PROFILES=main_ro:mysql://ro_user:secret@127.0.0.1:3306/myapp,main_rw:mysql://rw_user:secret@127.0.0.1/myapp
DB_PROFILES=
# Hard cap on rows returned by db_query (per call). Default 1000, max 10000.
DB_QUERY_MAX_ROWS=1000
# Default LIMIT injected when a SELECT has no LIMIT clause.
DB_QUERY_DEFAULT_LIMIT=100
# Query timeout in milliseconds.
DB_QUERY_TIMEOUT_MS=15000

# ===== Watchdog (proactive monitoring + Telegram alerts) =====
# Master switch. false = no background checks.
WATCHDOG_ENABLED=true
# How often the loop runs each check, in seconds.
WATCHDOG_INTERVAL_SEC=60
# Disk fill threshold per mount in %. >= this triggers an alert.
WATCHDOG_DISK_THRESHOLD=90
# Memory usage threshold in %.
WATCHDOG_MEM_THRESHOLD=90
# Load-average alert: triggers when loadavg(1min) > CPU_COUNT * this multiplier.
WATCHDOG_LOAD_MULTIPLIER=4
# Comma-separated URLs to probe with HTTP GET. Non-2xx/3xx triggers alert.
#   WATCHDOG_URLS=https://api.fhtop.top/health,https://site-b.example.com/
WATCHDOG_URLS=
# Same fingerprint won't be re-sent within this window (minutes).
WATCHDOG_DEDUP_MINUTES=30
# Alert if denied+timeout tool calls within the last hour exceed this count
# (potential prompt injection / abuse signal). Set 0 to disable.
WATCHDOG_AUDIT_DENY_THRESHOLD=10
# Comma-separated user ids to receive proactive alerts.
# Empty = falls back to TELEGRAM_ALLOWED_USER_IDS.
TELEGRAM_ALERT_USER_IDS=
